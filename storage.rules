rules_version = '2';

/**
 * Firebase Storage Security Rules — Ergon Work Management
 *
 * Structure: teams/{teamId}/projects/{projectId}/tasks/{taskId}/{mediaFile}
 *
 * Security model:
 * - Firestore rules are the primary security layer (team membership enforced there)
 * - Storage paths are opaque (teamId/projectId/taskId) — only discoverable via Firestore
 * - Therefore: authentication alone is sufficient here; non-members can't guess valid paths
 * - File size limit: 10MB
 */

service firebase.storage {
  match /b/{bucket}/o {

    // Allow list on team/project paths (needed for admin panel Storage tab + deleteProjectMedia)
    match /teams/{teamId}/projects/{projectId}/{allPaths=**} {
      allow list: if request.auth != null;
    }

    // Team-isolated storage path
    match /teams/{teamId}/projects/{projectId}/tasks/{taskId}/{mediaFile} {
      // Read and delete: authenticated users only
      allow read, delete: if request.auth != null;

      // Upload: authenticated users, max 10MB
      allow write: if request.auth != null &&
                      request.resource.size < 10 * 1024 * 1024;
    }

    // Deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
