rules_version = '2';

/**
 * Firebase Storage Security Rules — Ergon Work Management
 *
 * Structure: teams/{teamId}/projects/{projectId}/tasks/{taskId}/{mediaFile}
 *
 * Rules:
 * - Only authenticated users who are members of the team can access files
 * - Team membership is verified via Firestore cross-reference
 * - File size limit: 10MB
 */

service firebase.storage {
  match /b/{bucket}/o {

    // Check team membership via Firestore
    function isMember(teamId) {
      return request.auth != null &&
        request.auth.uid in firestore.get(
          /databases/(default)/documents/teams/$(teamId)
        ).data.memberIds;
    }

    // Allow list on team/project paths (needed for deleteProjectMedia in admin panel)
    match /teams/{teamId}/projects/{projectId}/{allPaths=**} {
      allow list: if isMember(teamId);
    }

    // Team-isolated storage: only members of the team can access
    match /teams/{teamId}/projects/{projectId}/tasks/{taskId}/{mediaFile} {
      // Read and delete: team members only
      allow read, delete: if isMember(teamId);

      // Upload: team members only, max 10MB
      allow write: if isMember(teamId) &&
                      request.resource.size < 10 * 1024 * 1024;
    }

    // Deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
